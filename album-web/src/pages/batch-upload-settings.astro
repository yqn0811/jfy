
---
import ManagementLayout from '@/layouts/ManagementLayout.astro'
import BatchUploadSettingsContent from '@/components/batch_upload_settings/BatchUploadSettingsContent.vue'

// Extract productId from URL params
const productId = new URL(Astro.request.url).searchParams.get('productId') || ''
---

<ManagementLayout title="协同编辑设置 - 家纺云">
  <BatchUploadSettingsContent 
    client:only="vue"
    productId={productId}
  />
</ManagementLayout>

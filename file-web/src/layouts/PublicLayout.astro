
---
import BaseLayout from '@/layouts/BaseLayout.astro'

interface Props {
  title?: string
  description?: string
}

const { title = 'Project', description = 'Built with Astro' } = Astro.props
---

<BaseLayout title={title} description={description}>
  <div class="min-h-screen bg-gradient-to-b from-background to-muted/20 flex flex-col">
    <!-- 顶部品牌区 -->
    <header class="border-b border-border bg-card/50 backdrop-blur-sm">
      <div class="max-w-2xl mx-auto px-6 py-4 flex items-center justify-center">
        <div class="flex items-center gap-2">
          <div class="w-8 h-8 bg-primary rounded-lg flex items-center justify-center">
            <svg class="w-5 h-5 text-white" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 2L2 7v10c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V7l-10-5z" />
            </svg>
          </div>
          <span class="text-lg font-bold text-foreground">织序传输</span>
        </div>
      </div>
    </header>

    <!-- 主内容区 -->
    <main class="flex-1 flex items-start justify-center py-8 md:py-12 px-4">
      <div class="w-full max-w-2xl">
        <slot />
      </div>
    </main>

    <!-- 页脚 -->
    <footer class="border-t border-border bg-card/30 py-6 text-center text-caption">
      <p>© 2026 织序传输助手。<a href="#" class="text-primary hover:underline">隐私政策</a> · <a href="#" class="text-primary hover:underline">服务条款</a></p>
    </footer>
  </div>
</BaseLayout>
